JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

######################################################
# 🗄️ MONGODB (Fixed: Standard Format for Atlas)
######################################################
# Maine ise sharded format mein rakha hai kyunki aapka ISP SRV block kar raha hai
MONGO_URI=mongodb://kdb12983_db_user:Kdb12345@ac-9riq5gs-shard-00-00.x04vx27.mongodb.net:27017,ac-9riq5gs-shard-00-01.x04vx27.mongodb.net:27017,ac-9riq5gs-shard-00-02.x04vx27.mongodb.net:27017/ludo_pro?ssl=true&replicaSet=atlas-75gpxk-shard-0&authSource=admin&retryWrites=true&w=majority

######################################################
# 🌐 FRONTEND & CORS (Vite standard)
######################################################
